# ─── Stripe ───────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_REPLACE_ME
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_REPLACE_ME

# Stripe webhook secret (from Dashboard > Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# ─── NOWPayments (Crypto) ──────────────────────────────────
# Get from https://nowpayments.io/dashboard
NOWPAYMENTS_API_KEY=REPLACE_ME
NOWPAYMENTS_IPN_SECRET=REPLACE_ME

# ─── Email Notifications ──────────────────────────────────
# Use any SMTP (Gmail App Password, SendGrid, Mailgun etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=orders@veyra-life.com
EMAIL_TO=admin@veyra-life.com

# ─── App ──────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app
